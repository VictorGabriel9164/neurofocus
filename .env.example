# Cole aqui a URL do seu banco PostgreSQL
# Formato: postgresql://USUARIO:SENHA@HOST:PORTA/NOME_DO_BANCO
DATABASE_URL="postgresql://postgres:suasenha@localhost:5432/neurofocus"

# Chave secreta para assinar os tokens JWT (coloque qualquer texto longo e seguro)
JWT_SECRET="troque_por_uma_chave_secreta_longa_e_aleatoria_aqui"

# Porta do servidor (padrão: 3001)
PORT=3001
